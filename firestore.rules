rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    // A2 — Notifications: shared helpers.
    //
    // `user_devices` is the only notifications collection a client can write.
    // Prefs live under `users/{uid}/settings/notifications` and are covered by
    // the existing `users/{uid}/{sub}/{docId}` wildcard below.
    //
    // A device doc is owned by the user whose uid it carries. On create, the
    // incoming uid MUST equal the auth uid. On update, the uid MUST NOT change.
    //
    // Helpers are self-defensive (each checks isAuth()) so they remain safe
    // if reused in other rules without an outer auth guard.
    function deviceUidMatchesAuth() {
      return isAuth() && request.resource.data.uid == request.auth.uid;
    }
    function deviceUidUnchanged() {
      return isAuth() && request.resource.data.uid == resource.data.uid;
    }

    // Field allowlist for user_devices create. Mirrors UserDevice in
    // shared/types/notifications.ts. Blocks field-injection on create;
    // bump this list whenever the schema adds a client-writable field.
    function deviceHasAllowedFieldsOnly() {
      return request.resource.data.keys().hasOnly([
        'uid', 'token', 'platform', 'userAgent',
        'active', 'installedAsPWA',
        'lastSeenAt', 'createdAt', 'updatedAt',
        'deactivatedAt', 'deactivationReason',
        'schemaVersion'
      ]);
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
      // Covers users/{uid}/settings/notifications (B1 prefs doc) + any other
      // per-user subcollections. Server (Admin SDK) bypasses rules anyway.
      match /{sub}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── A2: notifications collections ──────────────────────────────

    // user_devices: client-owned. Read/write your own devices only.
    // No hard delete from client — devices are soft-deleted (active=false).
    // GC of inactive devices runs server-side (Admin SDK).
    match /user_devices/{deviceId} {
      allow read:   if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if deviceUidMatchesAuth();
      allow update: if isAuth()
                    && resource.data.uid == request.auth.uid
                    && deviceUidUnchanged();
      allow delete: if false;
    }

    // scheduled_notifications: server-only. Admin SDK writes via Planner/Dispatcher.
    match /scheduled_notifications/{dedupeKey} {
      allow read, write: if false;
    }

    // notification_logs: server-only, append-only audit trail.
    match /notification_logs/{logId} {
      allow read, write: if false;
    }

    // dead_letter_notifications: server-only. Investigated via Admin Console.
    match /dead_letter_notifications/{id} {
      allow read, write: if false;
    }

    match /halaqahs/{halaqahId} {
      allow read: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.createdBy;

      match /duas/{duaId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow delete: if isAuth() && request.auth.uid == resource.data.authorUid;
      }
      match /naseeha/{msgId} {
        allow read, create: if isAuth();
      }
      match /challenges/{challengeId} {
        allow read: if isAuth();
        allow update: if isAuth();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
